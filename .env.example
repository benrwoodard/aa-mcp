# Copy this to .env and fill in your values
# Never commit .env to source control

# Required for all auth types
AW_COMPANY_ID=your_company_id_here

# --- OAuth (default, interactive) ---
AW_AUTH_TYPE=oauth
AW_CLIENT_ID=your_client_id_here
AW_CLIENT_SECRET=your_client_secret_here

# --- Server-to-Server / S2S (non-interactive, for shared/automated use) ---
# AW_AUTH_TYPE=s2s
# AW_AUTH_FILE=/path/to/adobe-credentials.json
