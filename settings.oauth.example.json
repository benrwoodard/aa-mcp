{
  "mcpServers": {
    "adobe-analytics": {
      "command": "uv",
      "args": ["--directory", "/REPLACE/path/to/aa-mcp", "run", "server.py"],
      "env": {
        "AW_CLIENT_ID": "REPLACE_YOUR_CLIENT_ID",
        "AW_CLIENT_SECRET": "REPLACE_YOUR_CLIENT_SECRET",
        "AW_COMPANY_ID": "REPLACE_YOUR_COMPANY_ID"
      }
    }
  }
}
