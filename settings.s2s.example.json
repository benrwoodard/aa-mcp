{
  "mcpServers": {
    "adobe-analytics": {
      "command": "uv",
      "args": ["--directory", "/REPLACE/path/to/aa-mcp", "run", "server.py"],
      "env": {
        "AW_AUTH_TYPE": "s2s",
        "AW_AUTH_FILE": "/REPLACE/path/to/adobe-credentials.json",
        "AW_COMPANY_ID": "REPLACE_YOUR_COMPANY_ID"
      }
    }
  }
}
